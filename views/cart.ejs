    <script>
        // Simulación de actualización de consentimiento después de que el usuario acepta
        setTimeout(() => {
            gtag('consent', 'update', {
                'ad_storage': 'granted',
                'analytics_storage': 'granted'
            });
        }, 1000); // Simula una actualización después de 1 segundo
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.17.0/xlsx.full.min.js"></script>
    <script>
        // Función para verificar si el elemento está visible en la pantalla
        function isElementInViewport(el) {
            const rect = el.getBoundingClientRect();
            return (
                rect.top <= (window.innerHeight || document.documentElement.clientHeight) &&
                rect.bottom >= 0
            );
        }

        // Función para agregar la clase 'visible' a las secciones que están en el viewport
        function handleScroll() {
            const sections = document.querySelectorAll('.fade-in-section');
            sections.forEach(section => {
                if (isElementInViewport(section)) {
                    section.classList.add('visible');
                }
            });
        }

        // Escuchar el evento de scroll para activar la animación
        window.addEventListener('scroll', handleScroll);

        // Ejecutar al cargar la página para detectar secciones visibles al inicio
        window.addEventListener('load', handleScroll);
    </script>
    <style>
        /* Estilos existentes para las imágenes de las tarjetas (mantener) */
        /* NOTA: Tu productCard.ejs usa la clase 'product-image',
           pero si tienes estilos generales para .card-img-top, los mantenemos aquí */
        .card-img-top {
            width: 100%;
            height: auto;
        }
         .product-image-container {
             /* Si necesitas estilos para el contenedor de la imagen */
             text-align: center; /* Centra la imagen si es más pequeña que el contenedor */
         }
         .product-image {
             max-width: 100%;
             height: auto;
             display: inline-block; /* Asegura que text-align: center funcione */
         }


        /* -- ESTILOS PARA EL LAYOUT DEL ENCABEZADO (Título, Logo, Ordenar) -- */

        /* Contenedor principal para el encabezado, usaremos Grid */
        .catalog-header-grid {
            display: grid;
            /* Definimos áreas para **móvil** (layout por defecto): Title, Sort, Logo apilados verticalmente */
            grid-template-areas:
                "title"
                "sort"
                "logo";
            grid-template-rows: auto auto auto; /* Filas automáticas para cada área */
            gap: 1rem; /* Espacio entre las áreas en móvil */
            align-items: center; /* Centrado vertical básico para elementos en sus áreas */
            margin-bottom: 1.5rem; /* Espacio debajo del encabezado */
        }

        /* Asignar áreas a los elementos dentro del Grid */
        .catalog-header-title {
            grid-area: title;
            margin-bottom: 0.5rem; /* Añadir un poco de espacio debajo del título en móvil */
        }

        .catalog-header-logo {
            grid-area: logo;
            text-align: center; /* Centrar el logo horizontalmente en móvil */
            margin-top: 0.5rem; /* Añadir un poco de espacio encima del logo en móvil */
            margin-bottom: 0.5rem; /* Espacio debajo del logo en móvil */
        }

        .catalog-header-sort {
            grid-area: sort;
            display: flex; /* Usar flexbox para alinear etiqueta y selector inline */
            /* Alinear a la derecha en móvil, como en la imagen */
            justify-content: flex-end;
            align-items: center; /* Centrar verticalmente etiqueta y selector */
            padding: 0; /* Asegurar que no haya padding extra */
            font-size: 0.9rem; /* Hacer el texto un poco más pequeño en móvil */
        }

        /* Ajustes para el selector dentro del contenedor de ordenación en móvil */
        .catalog-header-sort .form-inline {
             margin-bottom: 0; /* Asegurar que el form-inline no tenga margen inferior */
        }
        .catalog-header-sort .form-control-sm {
            /* form-control-sm de Bootstrap ya lo hace pequeño,
               pero puedes añadir más estilos si necesitas ajustar el ancho */
            max-width: 150px; /* Ancho máximo para el select en móvil */
            display: inline-block; /* Asegurar que se muestre inline con la label */
        }
        .catalog-header-sort label {
             margin-right: 0.5rem; /* Pequeño espacio entre label y select en móvil */
             margin-bottom: 0 !important; /* Eliminar margen inferior con alta prioridad */
             white-space: nowrap; /* Prevenir que "Ordenar por:" se rompa */
        }


        /* Media query para desktop (md y superior en Bootstrap) */
        @media (min-width: 768px) {
            .catalog-header-grid {
                /* Definimos áreas para **desktop**:
                   Título a la izquierda, Sort a la derecha en la primera fila;
                   Logo centrado en la segunda fila, abarcando ambas columnas. */
                grid-template-areas:
                    "title sort"
                    "logo  logo";
                grid-template-columns: 1fr auto; /* Columna de título flexible, columna de sort automática */
                grid-template-rows: auto auto; /* Dos filas automáticas */
                gap: 0.5rem 2rem; /* Espacio vertical (entre filas), Espacio horizontal (entre columnas) */
                align-items: center; /* Centrar verticalmente elementos en sus filas */
            }

            /* Re-alinear elementos en desktop según el grid */
            .catalog-header-title {
                 grid-area: title;
                 align-self: center; /* Asegura alineación vertical si la fila es más alta */
                 margin-bottom: 0; /* Confirmar sin margen */
            }

            .catalog-header-sort {
                grid-area: sort;
                justify-content: flex-end; /* Mantener alineado a la derecha */
                align-self: center; /* Asegura alineación vertical */
                font-size: 1rem; /* Restaurar tamaño de fuente para desktop */
            }
             .catalog-header-sort .form-inline {
                 margin-bottom: 0; /* Asegurar sin margen inferior */
             }
            .catalog-header-sort .form-control-sm {
                max-width: none; /* Eliminar el ancho máximo en desktop si se aplicó en móvil */
            }
            .catalog-header-sort label {
                margin-right: 0.5rem; /* Espacio entre label y select */
                margin-bottom: 0 !important; /* Confirmar sin margen */
            }


            .catalog-header-logo {
                grid-area: logo;
                text-align: center; /* Mantener centrado en desktop */
                margin-top: 1rem; /* Espacio encima del logo en desktop */
                margin-bottom: 1rem; /* Espacio debajo del logo en desktop */
                padding-top: 0; /* Eliminar padding superior si se usó en móvil */
            }
        }

        /* Estilos para la imagen del logo dentro del contenedor */
        .catalog-header-logo img {
             width: 8em; /* Mantener el tamaño del logo */
             height: auto;
             display: inline-block; /* Necesario para margin: auto o text-align: center */
        }

        /* Eliminar o modificar el estilo form-inline para mobile que causa que se apilen
           si existía en tu CSS original, ya que la nueva estructura maneja el layout */
        /* @media (max-width: 767.98px) {
             .form-inline { ... }
             .form-inline label { ... }
           }
           -> Si tenías esto en tus otros archivos CSS y te apilaba la etiqueta y el select en mobile, bórralo o coméntalo.
           Los nuevos estilos .catalog-header-sort .form-inline y sus hijos ya lo manejan.
        */

        /* -- FIN ESTILOS LAYOUT ENCABEZADO -- */

    </style>
    <!-- Meta Pixel Code -->
    <script>
        !function (f, b, e, v, n, t, s) {
            if (f.fbq) return; n = f.fbq = function () {
                n.callMethod ?
                    n.callMethod.apply(n, arguments) : n.queue.push(arguments)
            };
            if (!f._fbq) f._fbq = n; n.push = n; n.loaded = !0; n.version = '2.0';
            n.queue = []; t = b.createElement(e); t.async = !0;
            t.src = v; s = b.getElementsByTagName(e)[0];
            s.parentNode.insertBefore(t, s)
        }(window, document, 'script',
            'https://connect.facebook.net/en_US/fbevents.js');
