</head>

<body>
    <!-- Incluir Navbar -->
    <%- include('partials/navbarUser') %>

        <div class="container cart-container ">

                <!-- Título del catálogo -->
                <div class="catalog-header-title">
                    <h2 class="catalogo-title mb-0">CATÁLOGO</h2>
                </div>
            <!-- NUEVA ESTRUCTURA PARA TITULO, LOGO Y ORDENAR (Usando CSS Grid para el layout responsive) -->
            <!-- El orden de los divs aquí no importa tanto, el CSS Grid los posiciona por 'grid-area' -->
            <div class="catalog-header-grid">

            

                 <!-- Selector de ordenación -->
                <div class="catalog-header-sort">
                    <!-- form-inline de Bootstrap ayuda a alinear label y select horizontalmente -->
                    <div class="form-inline">
                        <label for="sort-select" class="mr-2 mb-0">Ordenar por:</label>
                        <!-- form-control-sm hace el select más pequeño -->
                        <select id="sort-select" class="form-control form-control-sm">
                            <option value="default">Fecha de carga</option>
                            <option value="price-asc">Precio: Menor a Mayor</option>
                            <option value="price-desc">Precio: Mayor a Menor</option>
                        </select>
                    </div>
                </div>

                 <!-- Logo del catálogo -->
                <!-- <div class="catalog-header-logo">
                    <img src="<%= imagenUrl2 %>" alt="iLoop Logo">
                </div> -->

            </div>
             <!-- FIN NUEVA ESTRUCTURA ENCABEZADO -->


            <!-- Barra lateral y modal de filtros (se mantiene igual) -->
            <!-- NOTA: La posición del "Buscador" sidebar/botón flotante no se tocó en esta modificación -->
            <div class="sidebar">
                <button class="filters-modal-btn-sidebar">Buscador</button>
            </div>

            <!-- Botón flotante para abrir los filtros en mobile -->
            <div class="filters-modal-btn-phone">🔍</div>

            <!-- Modal de filtros -->
            <div class="filters-modal">
                <div class="filters-modal-content">
                    <h3>Filtrar productos</h3>
                    <div class="input-group mb-3">
                        <input id="search-input" type="text" class="form-control" placeholder="Buscar productos">
                    </div>
                    <label for="model-filter">Modelo</label>
                    <select id="model-filter" class="form-control mb-2">
                        <option value="">Todos los modelos</option>
                        <% let uniqueModels=new Set(); products.forEach(product=> {
                            if (product.stock > 0 && !uniqueModels.has(product.name)) {
                            uniqueModels.add(product.name); %>
                            <option value="<%= product.name %>">
                                <%= product.name %>
                            </option>
                            <% } }); %>
                    </select>
                    <label for="type-filter">Tipo de Producto</label>
<select id="type-filter" class="form-control mb-2">
    <option value="">Todos los tipos</option>
    <%
        let uniqueTypes = new Set();
        products.forEach(product => {
            // Solo añadir tipos si el producto tiene stock y un tipo definido
            if (product.stock > 0 && product.tipo) {
                let productType = product.tipo.trim(); // Limpiar espacios
                if (productType && !uniqueTypes.has(productType)) {
                    uniqueTypes.add(productType);
    %>
                    <option value="<%= productType %>"><%= productType.charAt(0).toUpperCase() + productType.slice(1).toLowerCase() %></option>
    <%
                }
            }
        });
    %>
</select>
                    <label for="estado-filter">Estado</label>
                    <select id="estado-filter" class="form-control mb-2">
                        <option value="">Todos los estados</option>
                        <% let uniqueEstados=new Set(); products.forEach(product=> {
                            if (product.stock > 0 && product.estado) {
                            let estadoUpperCase = product.estado.toUpperCase();
                            if (!uniqueEstados.has(estadoUpperCase)) {
                            uniqueEstados.add(estadoUpperCase); %>
                            <option value="<%= estadoUpperCase %>">
                                <%= estadoUpperCase %>
                            </option>
                            <% } } }); %>
                    </select>
                    <label for="storage-filter">Almacenamiento (GB)</label>
                    <input id="storage-filter" type="number" class="form-control mb-2"
                        placeholder="Almacenamiento mínimo (GB)">
                    <label for="battery-filter">Batería mínima (%)</label>
                    <input id="battery-filter" type="number" class="form-control mb-2" placeholder="Batería mínima (%)">
                    <div class="buttons">
                        <button id="reset-button" class="btn btn-secondary">Resetear</button>
                        <button id="filter-button" class="btn btn-primary">Buscar</button>
                    </div>
                </div>
            </div>


            <!-- Sección de productos -->
            <section class="featured-products" style="min-height: 90vh;">
                 <!-- Contenedor de las tarjetas de producto -->
                <div class="products-container row" id="cart-items">
                    <% products.forEach((product, index) => { %>
                        <% if (product.stock > 0) { %>
                             <!-- Incluye el partial productCard.ejs para cada producto -->
                             <!-- Tu productCard.ejs YA tiene la clase 'product-card' y los data-attributes necesarios -->
                            <%- include('partials/productCard', { product: product, index: index }) %>
                        <% } %>
                    <% }); %>
                </div>
                <!-- Mensaje de "No se encontraron coincidencias" -->
                <div id="no-results-message" class="alert alert-warning" style="display: none;">
                    No se encontraron productos que coincidan con los filtros aplicados.
                </div>

            </section>
        </div>

        <%- include('partials/footer') %>

        <!-- Scripts (Mantén todos los scripts existentes) -->
        <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.3/dist/umd/popper.min.js"></script>
        <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
        <script src="/js/cart.js"></script>
        <!-- Google tag (gtag.js) ya está en el head -->

        <!-- Script para la ordenación de productos (Mantenido igual) -->
        <!-- Este script lee los data-attributes de las tarjetas para ordenar -->
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const sortSelect = document.getElementById('sort-select');
                const productsContainer = document.getElementById('cart-items');

                // Escucha los cambios en el desplegable de ordenación
                sortSelect.addEventListener('change', (event) => {
                    const sortBy = event.target.value; // 'default', 'price-asc', 'price-desc'
                    // Obtiene las tarjetas actuales. Asegúrate de que tengan la clase 'product-card'.
                    let productCards = Array.from(productsContainer.querySelectorAll('.product-card'));

                    // Lógica de ordenación
                    if (sortBy === 'default') {
                        // Ordenar por el índice original (fecha de carga)
                        productCards.sort((a, b) => {
                            // Lee el índice original del atributo data-index
                            const indexA = parseInt(a.dataset.index);
                            const indexB = parseInt(b.dataset.index);
                            return indexA - indexB;
                        });
                    } else if (sortBy === 'price-asc') {
                        // Ordenar por precio de menor a mayor
                        productCards.sort((a, b) => {
                            // Lee el precio del atributo data-price
                            const priceA = parseFloat(a.dataset.price);
                            const priceB = parseFloat(b.dataset.price);
                            return priceA - priceB;
                        });
                    } else if (sortBy === 'price-desc') {
                        // Ordenar por precio de mayor a menor
                        productCards.sort((a, b) => {
                             // Lee el precio del atributo data-price
                            const priceA = parseFloat(a.dataset.price);
                            const priceB = parseFloat(b.dataset.price);
                            return priceB - priceA;
                        });
                    }

                    // Re-insertar las tarjetas ordenadas en el contenedor
                    // Limpia el contenedor actual
                    productsContainer.innerHTML = '';
                    // Añade cada tarjeta en el nuevo orden
                    productCards.forEach(card => {
                        productsContainer.appendChild(card);
                    });

                    // NOTA sobre la interacción con filtros:
                    // Este script ordena los elementos HTML DENTRO del contenedor.
                    // Si ya tienes filtros aplicados que OCULTAN productos (usando `display: none`),
                    // este script de ordenación reordenará todos los elementos, visibles u ocultos,
                    // y los insertará en el nuevo orden. Los que estaban ocultos seguirán ocultos.
                    // Si aplicas un filtro DESPUÉS de ordenar, tu lógica de filtrado debería
                    // funcionar sobre el nuevo orden.
                    // Si aplicas un filtro, LUEGO ordenas, y LUEVO cambias el filtro de nuevo,
                    // la interacción puede requerir ajustar tu lógica de filtrado
                    // existente para que re-aplique los filtros sobre el conjunto de productos
                    // completo en su nuevo orden después de cada cambio en los filtros o la ordenación.
                    // La forma más robusta es manejar la lista de productos en un array JS
                    // y aplicar filtros/ordenación a ese array antes de renderizar el HTML.
                    // La solución aquí es la más simple para añadir la ordenación a la estructura existente.
                });

                // Si tienes lógica de filtrado que se ejecuta al cargar la página
                // o después de alguna interacción, asegúrate de que se combine bien
                // con esta ordenación. Por ejemplo, si reseteas filtros, podrías
                // querer volver a aplicar la ordenación actual.
                // Si llamas a una función para aplicar filtros, quizás necesites
                // re-ordenar los resultados después.
            });
        </script>

        <!-- NOTA: Tu script de filtrado (si lo tienes en /js/cart.js u otro lado)
             debe interactuar con las tarjetas en el DOM (seleccionándolas por clase 'product-card',
             leyendo sus data-attributes, y controlando su visibilidad).
             La estructura actual de los data-attributes en tu productCard.ejs es perfecta para esto. -->


</body>

</html>