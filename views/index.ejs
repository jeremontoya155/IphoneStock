<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Iloop</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/carts.css">
    <link rel="stylesheet" href="/css/modal.css">
    <link rel="stylesheet" href="/css/index.css"> <!-- Asegúrate de que la ruta a index.css sea correcta -->
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
    <!-- sc - Esta línea parece incompleta o un error tipográfico -->
    <!-- Incluir Font Awesome -->
    <script src="https://kit.fontawesome.com/a076d05399.js"></script>
    <!-- Incluir la librería SheetJS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.17.0/xlsx.full.min.js"></script>
    <!-- Mover este script al final del body es una mejor práctica si depende de elementos del DOM -->
    <!-- <script src="/js/cart.js"></script> -->


    <!-- Meta Pixel Code -->

    <script>
        !function (f, b, e, v, n, t, s) {
            if (f.fbq) return; n = f.fbq = function () {
                n.callMethod ?
                n.callMethod.apply(n, arguments) : n.queue.push(arguments)
            };
            if (!f._fbq) f._fbq = n; n.push = n; n.loaded = !0; n.version = '2.0';
            n.queue = []; t = b.createElement(e); t.async = !0;
            t.src = v; s = b.getElementsByTagName(e)[0];
            s.parentNode.insertBefore(t, s)
        }(window, document, 'script',
            'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', '1046128350193379');
        fbq('track', 'PageView');

        // Función para verificar si el elemento está visible en la pantalla
        function isElementInViewport(el) {
            const rect = el.getBoundingClientRect();
            return (
                rect.top <= (window.innerHeight || document.documentElement.clientHeight) &&
                rect.bottom >= 0
            );
        }

        // Función para agregar la clase 'visible' a las secciones que están en el viewport
        function handleScroll() {
            const sections = document.querySelectorAll('.fade-in-section');
            sections.forEach(section => {
                if (isElementInViewport(section)) {
                    section.classList.add('visible');
                }
            });
        }

        // Escuchar el evento de scroll para activar la animación
        window.addEventListener('scroll', handleScroll);

        // Ejecutar al cargar la página para detectar secciones visibles al inicio
        window.addEventListener('load', handleScroll);


        // Script para Facebook SDK (considerar si realmente lo necesitas en esta página)
        // Si no usas funciones de FB Login, compartir, etc. quizás no haga falta
        window.fbAsyncInit = function() {
          FB.init({
            appId      : '{your-app-id}', // Reemplaza con tu ID de App de Facebook
            cookie     : true,
            xfbml      : true,
            version    : 'v18.0' // Considera usar una versión más reciente si está disponible
          });

          FB.AppEvents.logPageView();

        };

        (function(d, s, id){
           var js, fjs = d.getElementsByTagName(s)[0];
           if (d.getElementById(id)) {return;}
           js = d.createElement(s); js.id = id;
           js.src = "https://connect.facebook.net/en_US/sdk.js";
           fjs.parentNode.insertBefore(js, fjs);
         }(document, 'script', 'facebook-jssdk'));
      </script>
    <noscript><img height="1" width="1" style="display:none"
            src="https://www.facebook.com/tr?id=1046128350193379&ev=PageView&noscript=1" /></noscript>
</head>

<body>
    <!-- Incluir Navbar -->
    <%- include('partials/navbarUser') %> <!-- Asegúrate de que la ruta 'partials/navbarUser' sea correcta -->

        <div class="container mt-4">

            <!-- Carousel -->
            <section class="carousel-section">
                <%- include('partials/carousel', { carouselItems: carouselItems }) %>
                    <% if (isAdmin) { %>
                        <div class="editar-carousel">
                            <a href="/edit-carousel" class="btn-generico">Editar carrusel</a>
                        </div>
                        <% }; %>
                            <section class="welcome-section">
                                <h1>¡Bienvenido!</h1>
                                <p>¿Estás listo para encontrar tu IPhone ideal?</p>

                                <img src="/imgs/icons-arrow.png" alt="flecha" class="welcome-flecha" />
                            </section>
            </section>
            <!-- Título y bienvenida -->

            <!-- Cards de productos (Productos Destacados) -->
            <!-- NOTA: Aquí estás mostrando los 6 productos más baratos. -->
            <!-- La lógica de ordenación que agregamos anteriormente es para la página /cart. -->
            <!-- Si quieres ordenación aquí también, necesitarías adaptar el script. -->
            <section class="featured-products fade-in-section">
                <h2>Productos destacados</h2>
                <div class="products-container row" id="featured-products-container"> <%# Usé otro ID para no confundir con #cart-items en /cart %>
                    <% // Filtrar los productos que tienen precio válido y luego ordenarlos por precio ascendente %>
                    <% const sortedProducts = products.filter(product => product.price > 0).sort((a, b) => a.price - b.price); %>

                    <% // Mostrar solo los 6 productos más baratos %>
                    <% sortedProducts.slice(0, 6).forEach((product, index) => { %> <%# CORRECCIÓN AQUÍ: Agregamos 'index' %>
                        <% if (product.stock > 0) { %>
                            <%# Pasamos 'index' al partial. Asegúrate que partials/productCard.ejs use 'index'. %>
                            <%- include('partials/productCard', { product: product, index: index }) %>
                        <% } %>
                    <% }); %>
                </div>
        </div>
        <div class="ver-mas fade-in-section">
            <a href="/cart" class="btn-generico">Ver más</a>
        </div>
        </section>

        <!-- Sección About -->
        <section class="about-section fade-in-section">
            <!-- Incluir sección 'about' -->
            <%- include('partials/about', { about: about }) %> <!-- Pasar el objeto `about` -->
        </section>

        <!-- Botones según el rol y tabla de productos (Admin) o mapa (Usuario) -->
        <div class="text-center mb-4 fade-in-section">
            <% if (isAdmin) { %>
                <h3>Lista completa de productos</h3>
                <div class="mb-3">
                    <a href="/new" class="btn-generico">Agregar Nuevo</a>
                    <button id="download-btn" class="btn-generico">Descargar lista</button>
                </div>
                <!-- Campo de búsqueda (para la tabla de administrador) -->
                <div class="input-group mb-3">
                    <input id="search-input-admin" type="text" class="form-control" placeholder="Buscar productos..."> <%# Usé otro ID para evitar conflicto %>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-bordered">
                        <thead class="thead-dark">
                            <tr>
                                <th>Imagen</th>
                                <th>Nombre</th>
                                <th>Descripción</th>
                                <th>Estado</th>
                                <th>Precio</th>
                                <th>Stock</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="products-table">
                            <% products.forEach(product=> { %>
                                <tr>
                                    <td data-label="Imagen"><img src="<%= product.img %>" alt="<%= product.name %>">
                                    </td>
                                    <td data-label="Nombre">
                                        <%= product.name %>
                                    </td>
                                    <td data-label="Descripción">
                                        <%= product.description %>
                                    </td>
                                    <td data-label="Estado">
                                        <%= product.estado %>
                                    </td>
                                    <td data-label="Precio">$<%= product.price %>
                                    </td>
                                    <td data-label="Stock">
                                        <%= product.stock %>
                                    </td>
                                    <td data-label="Acciones">
                                        <a href="/edit/<%= product.id %>" class="btn-generico">Editar</a>
                                    </td>
                                </tr>
                                <% }); %>
                        </tbody>
                    </table>
                </div>

                <% } else { %>
                    <%# Contenido para usuarios no administradores (mapa) %>
                    <div class="container my-2 py-2 fade-in-section">
                        <h3 class="about-title">Encontranos en:</h3>
                        <div class="iframe-container">
                            <iframe
                                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d27247.367835402438!2d-64.23651376765733!3d-31.38874232569808!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9432999729f8219b%3A0x52c9a2f615fdb8d8!2si%20loop!5e0!3m2!1ses-419!2sar!4v1723817758327!5m2!1ses-419!2sar"
                                width="300em" height="450" style="border:0;" allowfullscreen="" loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade"></iframe>
                        </div>
                    </div>
                    <% } %>
        </div>


        <!-- Incluir el footer -->
        <%- include('partials/footer') %> <!-- Asegúrate de que la ruta 'partials/footer' sea correcta -->

        <!-- Scripts -->
        <!-- Mover los scripts al final del body es buena práctica -->
        <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.3/dist/umd/popper.min.js"></script>
        <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
        <!-- Asumiendo que main.js es para el index y cart.js para el cart -->
        <script src="/js/main.js"></script>
        <script src="/js/cart.js"></script> <%# Solo si cart.js tiene lógica que debe correr en index también %>

     <script>
    $(document).ready(function () {
        $(document).on('hidden.bs.modal', function () {
            $('.modal-backdrop').remove(); // Elimina backdrop persistente
            $('body').removeClass('modal-open'); // Previene bloqueo del fondo
        });

        // Script para la funcionalidad de búsqueda en la tabla de administrador (si isAdmin)
        <% if (isAdmin) { %>
            const searchInputAdmin = document.getElementById('search-input-admin');
            const productTableBody = document.getElementById('products-table');
            const productTableRows = productTableBody.querySelectorAll('tr'); // Obtén las filas de la tabla

            searchInputAdmin.addEventListener('input', function() {
                const searchTerm = searchInputAdmin.value.toLowerCase();

                productTableRows.forEach(row => {
                    // Obtén el texto de las celdas que quieres buscar (Nombre, Descripción, Estado, Precio, Stock)
                    const name = row.cells[1].textContent.toLowerCase();
                    const description = row.cells[2].textContent.toLowerCase();
                    const estado = row.cells[3].textContent.toLowerCase();
                    const price = row.cells[4].textContent.toLowerCase();
                    const stock = row.cells[5].textContent.toLowerCase();

                    // Combina el texto de las celdas en una sola cadena para buscar
                    const rowText = `${name} ${description} ${estado} ${price} ${stock}`;

                    if (rowText.includes(searchTerm)) {
                        row.style.display = ''; // Muestra la fila
                    } else {
                        row.style.display = 'none'; // Oculta la fila
                    }
                });
            });
        <% } %>


    });
</script>

    </body>


</html>