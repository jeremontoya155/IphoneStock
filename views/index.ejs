<body>
    <!-- Incluir Navbar -->
    <%- include('partials/navbarUser') %> <!-- Asegúrate de que la ruta 'partials/navbarUser' sea correcta -->

        <div class="container mt-4">

            <!-- Carousel -->
            <section class="carousel-section">
                <% 
                  // Mostrar los productos más caros que contengan la palabra "ipgone" (nombre o descripción)
                  const keyword = 'iphone';
                  function normalizeText(s) {
                    return String(s || '').toLowerCase()
                      .normalize('NFD')            // descomponer acentos
                      .replace(/[\u0300-\u036f]/g, '') // quitar diacríticos
                      .trim();
                  }
                  const carouselItems = (products || [])
                    .filter(p => p.price > 0 && (
                      normalizeText(p.name).includes(keyword) ||
                      normalizeText(p.description).includes(keyword)
                    ))
                    .sort((a, b) => b.price - a.price) // mayor precio primero
                    .slice(0, 6); // limitar a 6 items (ajusta si quieres otro número)
                %>
                <%- include('partials/carousel', { carouselItems: carouselItems }) %>
                 <% if (isAdmin) { %>
                     <div class="editar-carousel">
                         <a href="/edit-carousel" class="btn-generico">Editar carrusel</a>
                     </div>
                     <% }; %>
                            <section class="welcome-section">
                                <h1>¡Bienvenido!</h1>
                                <p>¿Estás listo para encontrar tu IPhone ideal?</p>

                                <img src="/imgs/icons-arrow.png" alt="flecha" class="welcome-flecha" />
                            </section>
            </section>
            <!-- Título y bienvenida -->

            <!-- Cards de productos -->
            <section class="featured-products fade-in-section">
                <h2>Productos destacados</h2>
                <div class="products-container" id="cart-items">
                    <% // Filtrar los productos que tienen precio válido y luego ordenarlos por precio ascendente const
                        sortedProducts=products.filter(product=> product.price > 0).sort((a, b) => a.price - b.price);

                        // Mostrar solo los 6 productos más baratos
                        sortedProducts.slice(0, 6).forEach(product => {
                        %>
                        <% if (product.stock> 0) { %>
                            <%- include('partials/productCard', { product: product }) %>
                                <% } %>
                                    <% }); %>
                </div>
        </div>
        <div class="ver-mas fade-in-section">
            <a href="/cart" class="btn-generico">Ver más</a>
        </div>
        </section>

        <!-- Sección About -->
        <section class="about-section fade-in-section">
            <!-- Incluir sección 'about' -->
            <%- include('partials/about', { about: about }) %> <!-- Pasar el objeto `about` -->
        </section>

        <!-- Botones según el rol -->
        <div class="text-center mb-4 fade-in-section">
            <% if (isAdmin) { %>
                <h3>Lista completa de productos</h3>
                <div class="mb-3">
                    <a href="/new" class="btn-generico">Agregar Nuevo</a>
                    <button id="download-btn" class="btn-generico">Descargar lista</button>
                </div>
                <!-- Campo de búsqueda -->
                <div class="input-group mb-3">
                    <input id="search-input" type="text" class="form-control" placeholder="Buscar productos...">
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-bordered">
                        <thead class="thead-dark">
                            <tr>
                                <th>Imagen</th>
                                <th>Nombre</th>
                                <th>Descripción</th>
                                <th>Estado</th>
                                <th>Precio</th>
                                <th>Stock</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="products-table">
                            <% products.forEach(product=> { %>
                                <tr>
                                    <td data-label="Imagen"><img src="<%= product.img %>" alt="<%= product.name %>">
                                    </td>
                                    <td data-label="Nombre">
                                        <%= product.name %>
                                    </td>
                                    <td data-label="Descripción">
                                        <%
                                        // Función para limpiar solo caracteres problemáticos y normalizar acentos
                                        function cleanTextAdmin(text) {
                                          return text
                                            // Convertir caracteres de codificación problemáticos a 'a'
                                            .replace(/�/g, 'a')
                                            .replace(/Â/g, 'a')
                                            .replace(/â€™/g, "'")
                                            .replace(/â€œ/g, '"')
                                            .replace(/â€\u009d/g, '"')
                                            .replace(/€™/g, "'")
                                            
                                            // Correcciones específicas de palabras mal formadas
                                            .replace(/Resolucian/gi, 'Resolucion')
                                            .replace(/Resolucin/gi, 'Resolucion')
                                            
                                            // Diccionario de acentos: convertir á→a, é→e, etc.
                                            .replace(/á/g, 'a')
                                            .replace(/à/g, 'a')
                                            .replace(/â/g, 'a')
                                            .replace(/ä/g, 'a')
                                            .replace(/ã/g, 'a')
                                            .replace(/Á/g, 'A')
                                            .replace(/À/g, 'A')
                                            .replace(/Â/g, 'A')
                                            .replace(/Ä/g, 'A')
                                            .replace(/Ã/g, 'A')
                                            
                                            .replace(/é/g, 'e')
                                            .replace(/è/g, 'e')
                                            .replace(/ê/g, 'e')
                                            .replace(/ë/g, 'e')
                                            .replace(/É/g, 'E')
                                            .replace(/È/g, 'E')
                                            .replace(/Ê/g, 'E')
                                            .replace(/Ë/g, 'E')
                                            
                                            .replace(/í/g, 'i')
                                            .replace(/ì/g, 'i')
                                            .replace(/î/g, 'i')
                                            .replace(/ï/g, 'i')
                                            .replace(/Í/g, 'I')
                                            .replace(/Ì/g, 'I')
                                            .replace(/Î/g, 'I')
                                            .replace(/Ï/g, 'I')
                                            
                                            .replace(/ó/g, 'o')
                                            .replace(/ò/g, 'o')
                                            .replace(/ô/g, 'o')
                                            .replace(/ö/g, 'o')
                                            .replace(/õ/g, 'o')
                                            .replace(/Ó/g, 'O')
                                            .replace(/Ò/g, 'O')
                                            .replace(/Ô/g, 'O')
                                            .replace(/Ö/g, 'O')
                                            .replace(/Õ/g, 'O')
                                            
                                            .replace(/ú/g, 'u')
                                            .replace(/ù/g, 'u')
                                            .replace(/û/g, 'u')
                                            .replace(/ü/g, 'u')
                                            .replace(/Ú/g, 'U')
                                            .replace(/Ù/g, 'U')
                                            .replace(/Û/g, 'U')
                                            .replace(/Ü/g, 'U')
                                            
                                            // Casos especiales
                                            .replace(/ñ/g, 'n')
                                            .replace(/Ñ/g, 'N')
                                            .replace(/ç/g, 'c')
                                            .replace(/Ç/g, 'C')
                                            
                                            // Limpiar símbolos de pulgadas problemáticos
                                            .replace(/[��″"]/g, ' pulgadas')
                                            .replace(/pulgadas pulgadas/g, ' pulgadas')
                                            
                                            // Limpiar espacios múltiples
                                            .replace(/\s+/g, ' ')
                                            .trim();
                                        }
                                        %>
                                        <%= cleanTextAdmin(product.description) %>
                                    </td>
                                    <td data-label="Estado">
                                        <%= product.estado %>
                                    </td>
                                    <td data-label="Precio">$<%= product.price %>
                                    </td>
                                    <td data-label="Stock">
                                        <%= product.stock %>
                                    </td>
                                    <td data-label="Acciones">
                                        <a href="/edit/<%= product.id %>" class="btn-generico">Editar</a>
                                    </td>
                                </tr>
                                <% }); %>
                        </tbody>
                    </table>
                </div>

                <% } else { %>

                    <div class="container my-2 py-2 fade-in-section">
                        <h3 class="about-title">Encontranos en:</h3>
                        <div class="iframe-container">
                            <iframe
                                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d27247.367835402438!2d-64.23651376765733!3d-31.38874232569808!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9432999729f8219b%3A0x52c9a2f615fdb8d8!2si%20loop!5e0!3m2!1ses-419!2sar!4v1723817758327!5m2!1ses-419!2sar"
                                width="300em" height="450" style="border:0;" allowfullscreen="" loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade"></iframe>
                        </div>
                    </div>
                    <% } %>
        </div>
        </div>




