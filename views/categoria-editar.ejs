<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Categoría - <%= categoria.nombre %></title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        body { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); min-height: 100vh; }
        .container { margin-top: 100px; padding-bottom: 40px; }
        .edit-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
            overflow: hidden;
        }
        .edit-header {
            background: linear-gradient(135deg, #800020 0%, #a00030 100%);
            color: white;
            padding: 30px;
        }
        .edit-header h2 { margin: 0; font-weight: 700; }
        .edit-body { padding: 40px; }
        .form-group label { font-weight: 600; color: #333; margin-bottom: 8px; }
        .form-control { 
            border-radius: 10px; 
            border: 2px solid #e0e0e0; 
            padding: 12px 16px;
            transition: all 0.3s;
        }
        .form-control:focus { 
            border-color: #800020; 
            box-shadow: 0 0 0 3px rgba(128, 0, 32, 0.1);
        }
        .color-picker-container {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        .color-picker-container input[type="color"] {
            width: 60px;
            height: 60px;
            border: none;
            border-radius: 10px;
            cursor: pointer;
        }
        .color-preview-large {
            width: 100px;
            height: 60px;
            border-radius: 10px;
            border: 2px solid #e0e0e0;
        }
        .emoji-selector {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 10px;
        }
        .emoji-btn {
            width: 45px;
            height: 45px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            background: white;
            font-size: 1.5rem;
            cursor: pointer;
            transition: all 0.2s;
        }
        .emoji-btn:hover, .emoji-btn.active {
            border-color: #800020;
            background: #fff0f3;
            transform: scale(1.1);
        }
        .plan-card {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 15px;
            border: 2px solid #e0e0e0;
            transition: all 0.3s;
        }
        .plan-card:hover { border-color: #800020; }
        .btn-add-plan {
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 10px;
            font-weight: 600;
        }
        .btn-add-plan:hover { transform: translateY(-2px); color: white; }
        .btn-remove-plan {
            background: #dc3545;
            color: white;
            border: none;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            font-size: 1.2rem;
        }
        .btn-save {
            background: linear-gradient(135deg, #800020 0%, #a00030 100%);
            color: white;
            border: none;
            padding: 15px 40px;
            border-radius: 12px;
            font-weight: 700;
            font-size: 1.1rem;
            transition: all 0.3s;
        }
        .btn-save:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(128, 0, 32, 0.4); color: white; }
        .btn-back {
            background: #6c757d;
            color: white;
            padding: 15px 30px;
            border-radius: 12px;
            font-weight: 600;
        }
        .btn-back:hover { background: #5a6268; color: white; text-decoration: none; }
        .section-title {
            font-size: 1.2rem;
            font-weight: 700;
            color: #800020;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #800020;
        }
        .current-icon {
            font-size: 3rem;
            padding: 15px;
            background: #f8f9fa;
            border-radius: 15px;
            display: inline-block;
        }
    </style>
</head>
<body>
    <%- include('partials/navbarUser', { user: user }) %>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="edit-card">
                    <div class="edit-header">
                        <div class="d-flex align-items-center">
                            <span class="current-icon mr-3"><%= categoria.icono || '📦' %></span>
                            <div>
                                <h2>✏️ Editar Categoría</h2>
                                <p class="mb-0 opacity-75">Modificando: <%= categoria.nombre %></p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="edit-body">
                        <form action="/edit-category/<%= categoria.id %>" method="POST">
                            <!-- Información Básica -->
                            <div class="section-title">📋 Información Básica</div>
                            
                            <div class="row">
                                <div class="col-md-8">
                                    <div class="form-group">
                                        <label>Nombre de la Categoría *</label>
                                        <input type="text" class="form-control" name="nombre" 
                                               value="<%= categoria.nombre %>" required 
                                               placeholder="Ej: iPhones, Accesorios...">
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Orden</label>
                                        <input type="number" class="form-control" name="orden" 
                                               value="<%= categoria.orden || 0 %>" min="0">
                                    </div>
                                </div>
                            </div>
                            
                            <div class="form-group">
                                <label>Descripción</label>
                                <textarea class="form-control" name="descripcion" rows="3" 
                                          placeholder="Describe brevemente esta categoría..."><%= categoria.descripcion || '' %></textarea>
                            </div>

                            <!-- Apariencia -->
                            <div class="section-title mt-4">🎨 Apariencia</div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Color de la Categoría</label>
                                        <div class="color-picker-container">
                                            <input type="color" id="colorPicker" name="color" 
                                                   value="<%= categoria.color || '#800020' %>">
                                            <div class="color-preview-large" id="colorPreview" 
                                                 style="background-color: <%= categoria.color || '#800020' %>;"></div>
                                            <input type="text" class="form-control" id="colorText" 
                                                   value="<%= categoria.color || '#800020' %>" 
                                                   pattern="^#[0-9A-Fa-f]{6}$" style="width: 120px;">
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Icono (Emoji)</label>
                                        <input type="text" class="form-control" id="iconoInput" name="icono" 
                                               value="<%= categoria.icono || '' %>" maxlength="2" 
                                               placeholder="Selecciona abajo">
                                        <div class="emoji-selector">
                                            <% const emojis = ['📱', '💻', '🎧', '⌚', '📦', '🔌', '🎮', '📷', '🖥️', '⚡', '🛒', '🎁', '✨', '🔥', '💎']; %>
                                            <% emojis.forEach(emoji => { %>
                                                <button type="button" class="emoji-btn <%= categoria.icono === emoji ? 'active' : '' %>" 
                                                        onclick="selectEmoji('<%= emoji %>')"><%= emoji %></button>
                                            <% }); %>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Planes de Cuotas -->
                            <div class="section-title mt-4">💳 Planes de Cuotas</div>
                            <p class="text-muted mb-3">Configura los planes de financiamiento disponibles para productos de esta categoría</p>
                            
                            <input type="hidden" name="cuotas_max" value="0">
                            <input type="hidden" name="interes_cuotas" value="0">
                            
                            <div id="planesContainer">
                                <% 
                                let planes = [];
                                try { planes = JSON.parse(categoria.cuotas_planes || '[]'); } catch(e) { planes = []; }
                                if (planes.length === 0 && categoria.cuotas_max > 0) {
                                    planes = [{cuotas: categoria.cuotas_max, interes: categoria.interes_cuotas || 0}];
                                }
                                %>
                                <% planes.forEach((plan, index) => { %>
                                <div class="plan-card" data-index="<%= index %>">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-grow-1">
                                            <div class="row">
                                                <div class="col-md-5">
                                                    <label class="small text-muted">Cantidad de Cuotas</label>
                                                    <input type="number" class="form-control" name="plan_cuotas[]" 
                                                           value="<%= plan.cuotas %>" min="1" max="48" required>
                                                </div>
                                                <div class="col-md-5">
                                                    <label class="small text-muted">Interés (%)</label>
                                                    <input type="number" step="0.01" class="form-control" name="plan_interes[]" 
                                                           value="<%= plan.interes || 0 %>" min="0">
                                                </div>
                                                <div class="col-md-2 d-flex align-items-end">
                                                    <button type="button" class="btn-remove-plan" onclick="removePlan(this)">×</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <% }); %>
                            </div>
                            
                            <button type="button" class="btn btn-add-plan" onclick="addPlan()">
                                ➕ Agregar Plan de Cuotas
                            </button>

                            <!-- Botones -->
                            <div class="d-flex justify-content-between mt-5 pt-4 border-top">
                                <a href="/categorias" class="btn btn-back">← Volver a Categorías</a>
                                <button type="submit" class="btn btn-save">💾 Guardar Cambios</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
    <script>
        // Color picker sync
        const colorPicker = document.getElementById('colorPicker');
        const colorPreview = document.getElementById('colorPreview');
        const colorText = document.getElementById('colorText');

        colorPicker.addEventListener('input', function() {
            colorPreview.style.backgroundColor = this.value;
            colorText.value = this.value;
        });

        colorText.addEventListener('input', function() {
            if (/^#[0-9A-Fa-f]{6}$/.test(this.value)) {
                colorPicker.value = this.value;
                colorPreview.style.backgroundColor = this.value;
            }
        });

        // Emoji selector
        function selectEmoji(emoji) {
            document.getElementById('iconoInput').value = emoji;
            document.querySelectorAll('.emoji-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
        }

        // Planes de cuotas
        let planIndex = <%= planes.length %>;

        function addPlan() {
            const container = document.getElementById('planesContainer');
            const html = `
                <div class="plan-card" data-index="${planIndex}">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <div class="row">
                                <div class="col-md-5">
                                    <label class="small text-muted">Cantidad de Cuotas</label>
                                    <input type="number" class="form-control" name="plan_cuotas[]" min="1" max="48" required placeholder="Ej: 3, 6, 12">
                                </div>
                                <div class="col-md-5">
                                    <label class="small text-muted">Interés (%)</label>
                                    <input type="number" step="0.01" class="form-control" name="plan_interes[]" value="0" min="0" placeholder="0 = sin interés">
                                </div>
                                <div class="col-md-2 d-flex align-items-end">
                                    <button type="button" class="btn-remove-plan" onclick="removePlan(this)">×</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            container.insertAdjacentHTML('beforeend', html);
            planIndex++;
        }

        function removePlan(btn) {
            btn.closest('.plan-card').remove();
        }
    </script>
</body>
</html>
