<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Producto - <%= product.name %>
    </title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/pages/productPage.css">
</head>

<body>

    <!-- Incluir Navbar -->
    <%- include('partials/navbarUser') %> <!-- Asegúrate de que la ruta 'partials/navbarUser' sea correcta -->
        <header>
            <h1>Detalles del Producto</h1>
        </header>

        <main class="productPage-container">
            <div class="productPage-main">
                <!-- Imagen del producto -->
                <div class="productPage-image">
                    <% if (product.img) { %>
                        <img src="<%= product.img %>" alt="Imagen de <%= product.name %>">
                        <% } else { %>
                            <p>Imagen no disponible</p>
                            <% } %>
                </div>

                <!-- Detalles del producto -->
                <div class="productPage-details">
                    <h1 class="productPage-title">
                        <%= product.name %>
                    </h1>

                    <% if (product.categoria_nombre) { %>
                    <p><strong>Categoría:</strong>
                        <span style="background: <%= product.categoria_color || '#0052A3' %>; color: white; padding: 0.25rem 0.75rem; border-radius: 15px; display: inline-block;">
                            <%= product.categoria_icono %> <%= product.categoria_nombre %>
                        </span>
                    </p>
                    <% } %>

                    <p><strong>Estado:</strong>
                        <%= product.estado %>
                    </p>
                    <p><strong>Almacenamiento:</strong>
                        <%= product.almacenamiento %> GB
                    </p>
                    <p><strong>Batería:</strong>
                        <%= product.bateria %>% 
                    </p>
                    <p><strong>Descripción:</strong>
                        <%
                        // Función para limpiar solo caracteres problemáticos y normalizar acentos
                        function cleanText(text) {
                          return text
                            // Convertir caracteres de codificación problemáticos a 'a'
                            .replace(/�/g, 'a')
                            .replace(/Â/g, 'a')
                            .replace(/â€™/g, "'")
                            .replace(/â€œ/g, '"')
                            .replace(/â€\u009d/g, '"')
                            .replace(/€™/g, "'")
                            
                            // Correcciones específicas de palabras mal formadas
                            .replace(/Resolucian/gi, 'Resolucion')
                            .replace(/Resolucin/gi, 'Resolucion')
                            
                            // Diccionario de acentos: convertir á→a, é→e, etc.
                            .replace(/á/g, 'a')
                            .replace(/à/g, 'a')
                            .replace(/â/g, 'a')
                            .replace(/ä/g, 'a')
                            .replace(/ã/g, 'a')
                            .replace(/Á/g, 'A')
                            .replace(/À/g, 'A')
                            .replace(/Â/g, 'A')
                            .replace(/Ä/g, 'A')
                            .replace(/Ã/g, 'A')
                            
                            .replace(/é/g, 'e')
                            .replace(/è/g, 'e')
                            .replace(/ê/g, 'e')
                            .replace(/ë/g, 'e')
                            .replace(/É/g, 'E')
                            .replace(/È/g, 'E')
                            .replace(/Ê/g, 'E')
                            .replace(/Ë/g, 'E')
                            
                            .replace(/í/g, 'i')
                            .replace(/ì/g, 'i')
                            .replace(/î/g, 'i')
                            .replace(/ï/g, 'i')
                            .replace(/Í/g, 'I')
                            .replace(/Ì/g, 'I')
                            .replace(/Î/g, 'I')
                            .replace(/Ï/g, 'I')
                            
                            .replace(/ó/g, 'o')
                            .replace(/ò/g, 'o')
                            .replace(/ô/g, 'o')
                            .replace(/ö/g, 'o')
                            .replace(/õ/g, 'o')
                            .replace(/Ó/g, 'O')
                            .replace(/Ò/g, 'O')
                            .replace(/Ô/g, 'O')
                            .replace(/Ö/g, 'O')
                            .replace(/Õ/g, 'O')
                            
                            .replace(/ú/g, 'u')
                            .replace(/ù/g, 'u')
                            .replace(/û/g, 'u')
                            .replace(/ü/g, 'u')
                            .replace(/Ú/g, 'U')
                            .replace(/Ù/g, 'U')
                            .replace(/Û/g, 'U')
                            .replace(/Ü/g, 'U')
                            
                            // Casos especiales
                            .replace(/ñ/g, 'n')
                            .replace(/Ñ/g, 'N')
                            .replace(/ç/g, 'c')
                            .replace(/Ç/g, 'C')
                            
                            // Limpiar símbolos de pulgadas problemáticos
                            .replace(/[��″"]/g, ' pulgadas')
                            .replace(/pulgadas pulgadas/g, ' pulgadas')
                            
                            // Limpiar espacios múltiples
                            .replace(/\s+/g, ' ')
                            .trim();
                        }
                        %>
                        <%= cleanText(product.description) %>
                    </p>
                    <p><strong>Stock:</strong>
                        <%= product.stock %>
                    </p>
                    <% if (product.tiene_oferta_vigente) { %>
                    <%
                      const cotiz = typeof cotizacionDolar !== 'undefined' ? cotizacionDolar : 1200;
                      const monedaProd = product.moneda || 'USD';
                      const esUSD = monedaProd === 'USD';
                      const simbolo = esUSD ? 'USD' : 'ARS $';
                      const mostrarPesos = typeof mostrarPrecioPesos !== 'undefined' ? mostrarPrecioPesos : true;
                    %>
                    <div style="margin-bottom: 10px;">
                      <p style="margin-bottom: 2px;"><strong>Precio:</strong></p>
                      <span style="font-size: 0.95rem; color: #86868b; text-decoration: line-through;"><%= simbolo %> <%= product.price %></span>
                      <span style="font-size: 1.4rem; color: #ff3b30; font-weight: 700; margin-left: 8px;"><%= simbolo %> <%= product.precio_final %></span>
                      <% if (esUSD && mostrarPesos) { %>
                      <div style="font-size: 0.95rem; color: #2e7d32; font-weight: 600; margin-top: 4px;">
                        ARS $<%= Math.round(product.precio_final * cotiz).toLocaleString('es-AR') %>
                      </div>
                      <% } %>
                      <div style="margin-top: 4px;">
                        <span style="background: rgba(52,199,89,0.12); color: #34c759; padding: 3px 10px; border-radius: 12px; font-size: 0.85rem; font-weight: 600;">
                          Ahorrás <%= simbolo %> <%= (product.price - product.precio_final).toFixed(2) %>
                        </span>
                        <% if (product.es_oferta_general && product.nombre_oferta_general) { %>
                        <span style="background: rgba(255,59,48,0.08); color: #ff3b30; padding: 3px 10px; border-radius: 12px; font-size: 0.8rem; font-weight: 600; margin-left: 6px;">
                          <%= product.nombre_oferta_general %>
                        </span>
                        <% } else if (product.tipo_descuento === 'porcentaje') { %>
                        <span style="background: rgba(255,59,48,0.08); color: #ff3b30; padding: 3px 10px; border-radius: 12px; font-size: 0.8rem; font-weight: 600; margin-left: 6px;">
                          -<%= product.valor_descuento %>%
                        </span>
                        <% } %>
                      </div>
                    </div>
                    <% } else { %>
                    <%
                      const cotiz2 = typeof cotizacionDolar !== 'undefined' ? cotizacionDolar : 1200;
                      const monedaProd2 = product.moneda || 'USD';
                      const esUSD2 = monedaProd2 === 'USD';
                      const simbolo2 = esUSD2 ? 'USD' : 'ARS $';
                      const mostrarPesos2 = typeof mostrarPrecioPesos !== 'undefined' ? mostrarPrecioPesos : true;
                    %>
                    <p><strong>Precio:</strong> <%= simbolo2 %> <%= product.price %>
                    </p>
                    <% if (esUSD2 && mostrarPesos2) { %>
                    <p style="color: #2e7d32; font-weight: 600; font-size: 1rem; margin-top: -8px;">
                      ARS $<%= Math.round(product.price * cotiz2).toLocaleString('es-AR') %>
                    </p>
                    <% } %>
                    <% } %>

                    <% 
                      let planesProducto = [];
                      try { planesProducto = JSON.parse(product.cuotas_planes || '[]'); } catch(e) { planesProducto = []; }
                      if (planesProducto.length === 0 && product.cuotas_max && product.cuotas_max > 0) {
                        planesProducto = [{cuotas: product.cuotas_max, interes: product.interes_cuotas || 0}];
                      }
                      const cotizCuotas = typeof cotizacionDolar !== 'undefined' ? cotizacionDolar : 1200;
                      const esUSDCuotas = (product.moneda || 'USD') === 'USD';
                      const mostrarPesosCuotas = typeof mostrarPrecioPesos !== 'undefined' ? mostrarPrecioPesos : true;
                    %>
                    <% if (planesProducto.length > 0 && mostrarPesosCuotas) { %>
                    <div style="margin-top: 8px; margin-bottom: 12px; padding: 10px 14px; background: rgba(46,125,50,0.06); border-radius: 10px; border: 1px solid rgba(46,125,50,0.15);">
                        <div style="font-size: 0.9rem; color: #2e7d32; font-weight: 700; margin-bottom: 6px;">💳 Opciones de cuotas <span style="font-size: 0.75rem; font-weight: 400; color: #666;">(en pesos argentinos)</span></div>
                        <% const precioBase = product.tiene_oferta_vigente ? product.precio_final : product.price; %>
                        <% const precioBasePesosProd = esUSDCuotas ? (precioBase * cotizCuotas) : precioBase; %>
                        <% planesProducto.forEach(plan => { %>
                        <% 
                            const totalPlan = plan.interes > 0 
                                ? (precioBasePesosProd * (1 + plan.interes / 100)) 
                                : precioBasePesosProd;
                            const valorCuotaPlan = Math.round(totalPlan / plan.cuotas).toLocaleString('es-AR');
                        %>
                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 4px 0; border-bottom: 1px solid rgba(46,125,50,0.08);">
                            <span style="font-size: 0.9rem; color: #333; font-weight: 600;"><%= plan.cuotas %> cuotas</span>
                            <span style="font-size: 0.9rem; color: #2e7d32; font-weight: 700;">ARS $<%= valorCuotaPlan %>/mes</span>
                        </div>
                        <% }); %>
                    </div>
                    <% } %>

                    <!-- Botones de acción -->
                    <div class="productPage-actions">
                        <% if (isAdmin) { %>
                            <a href="/edit/<%= product.id %>" class="productPage-editButton">Editar Producto</a>
                            <% } %>
                            <div class="productPage-actionCentered">
                                <form action="/buy/<%= product.id %>" method="POST" class="d-inline"
                                    onclick="event.stopPropagation()">
                                    <button type="submit" class="btn-ver-mas-small productPage-consultar">Consultar</button>
                                </form>
                            </div>
                    </div>
                </div>
            </div>
        </main>

</body>

</html>