<div class="product-card fade-in-section" 
     data-stock="<%= product.stock %>" 
     data-estado="<%= product.estado %>" 
     data-storage="<%= product.almacenamiento %>" 
     data-battery="<%= product.bateria %>" 
     data-model="<%= product.name %>" 
     data-price="<%= product.price %>"
     data-toggle="modal" 
     data-target="#productModal<%= product.id %>">


  <div class="product-image-container">
    <img src="<%= product.img %>" alt="<%= product.name %>" class="product-image">
  </div>

  <div class="product-details">
    <% 
    // Verificar si el nombre tiene "/" 
    const hasSlash = product.name.includes('/');
    if (hasSlash) {
      // Dividir el nombre por "/" y mostrar cada parte en una línea
      const nameParts = product.name.split('/').map(part => part.trim());
    %>
      <div class="product-name-parts" style="margin-bottom: 12px;">
        <% nameParts.forEach(part => { %>
          <h3 class="product-name-line" style="font-size: 0.95rem; color: #1d1d1f; font-weight: 600; margin: 2px 0; text-align: left; letter-spacing: -0.01em; line-height: 1.3;">
            <%= part %>
          </h3>
        <% }); %>
      </div>
    <% } else { %>
      <h3 class="product-name" style="font-size: 1.1rem; color: #1d1d1f; font-weight: 600; margin-top: 12px; margin-bottom: 8px; text-align: left; letter-spacing: -0.01em; line-height: 1.3;">
        <%= product.name %>
      </h3>
    <% } %>

    <p class="product-price precio" style="font-size: 1.1rem; color: #1d1d1f; margin-bottom: 8px; margin-top: 8px; text-align: left; font-weight: 600;">
      USD <%= product.price %>
    </p>

    <div class="product-footer">
      <div class="battery-status">
        <img src="/imgs/bateria.png" alt="Battery Icon" class="battery-icon">
        <p class="bateria">
          <span class="bateria-num">
            <%= product.bateria %>
          </span>% 
        </p>
      </div>
      
      <!-- Botón para redirigir a la hoja de producto -->
      <form action="/product" method="POST" class="d-inline" onclick="event.stopPropagation()">
        <input type="hidden" name="productId" value="<%= product.id %>">
        <button type="submit" class="btn-ver-mas-small">Ver más</button>
      </form>
      
      
    </div>
  </div>
</div>
