<div class="product-card fade-in-section" 
     data-stock="<%= product.stock %>" 
     data-estado="<%= product.estado %>" 
     data-storage="<%= product.almacenamiento %>" 
     data-battery="<%= product.bateria %>" 
     data-model="<%= product.name %>" 
     data-toggle="modal" 
     data-target="#productModal<%= product.id %>">


  <div class="product-image-container">
    <img src="<%= product.img %>" alt="<%= product.name %>" class="product-image">
  </div>

  <div class="product-details">
    <h3 class="product-name">
      <%= product.name %>
    </h3>
    
    <% if (product.description) { %>
      <p class="product-description" style="font-size: 0.75rem; color: #666; margin-bottom: 8px; line-height: 1.2; height: 40px; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
        <%= product.description
          .replace(/ï¿½/g, '')
          .replace(/Resoluciï¿½n/gi, 'Resolucion')
          .replace(/resoluciï¿½n/gi, 'resolucion')
          .replace(/cï¿½mara/gi, 'camara')
          .replace(/Cï¿½mara/gi, 'Camara')
          .replace(/baterï¿½a/gi, 'bateria')
          .replace(/Baterï¿½a/gi, 'Bateria')
          .replace(/telï¿½fono/gi, 'telefono')
          .replace(/Telï¿½fono/gi, 'Telefono')
          .replace(/mï¿½vil/gi, 'movil')
          .replace(/Mï¿½vil/gi, 'Movil')
          .replace(/panĂ‚talla/gi, 'pantalla')
          .replace(/Pantalla:/gi, 'Pantalla:')
          .replace(/10\.9ï¿½ï¿½/gi, '10.9 pulgadas')
          .replace(/5\.4ï¿½ï¿½/gi, '5.4 pulgadas')
          .replace(/6\.1ï¿½ï¿½/gi, '6.1 pulgadas')
          .replace(/6\.7ï¿½ï¿½/gi, '6.7 pulgadas')
          .replace(/ï¿½ï¿½/gi, ' pulgadas')
          .replace(/[^\x00-\x7F]/g, '')
        %>
      </p>
    <% } %>
    
    <p class="product-space estado">
      <%= product.estado %>
    </p>
    <p class="product-space almacenamiento">
      <%= product.almacenamiento %> GB
    </p>

    <p class="product-price precio">
      USD <%= product.price %>
    </p>

    <div class="product-footer">
      <div class="battery-status">
        <img src="/imgs/bateria.png" alt="Battery Icon" class="battery-icon">
        <p class="bateria">
          <span class="bateria-num">
            <%= product.bateria %>
          </span>% 
        </p>
      </div>
      
      <!-- BotĂ³n para redirigir a la hoja de producto -->
      <form action="/product" method="POST" class="d-inline" onclick="event.stopPropagation()">
        <input type="hidden" name="productId" value="<%= product.id %>">
        <button type="submit" class="btn-ver-mas-small">Ver mĂ¡s</button>
      </form>
      
      
    </div>
  </div>
</div>
