<div class="product-card fade-in-section" 
     data-stock="<%= product.stock %>" 
     data-estado="<%= product.estado %>" 
     data-storage="<%= product.almacenamiento %>" 
     data-battery="<%= product.bateria %>" 
     data-model="<%= product.name %>" 
     data-toggle="modal" 
     data-target="#productModal<%= product.id %>">


  <div class="product-image-container">
    <img src="<%= product.img %>" alt="<%= product.name %>" class="product-image">
  </div>

  <div class="product-details">
    <h3 class="product-name">
      <%= product.name %>
    </h3>
    
    <% if (product.description) { %>
      <p class="product-description" style="font-size: 0.75rem; color: #666; margin-bottom: 8px; line-height: 1.2; height: 40px; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
        <%
        // Función para limpiar solo caracteres problemáticos y normalizar acentos
        function cleanText(text) {
          return text
            // Convertir caracteres de codificación problemáticos a 'a'
            .replace(/�/g, 'a')
            .replace(/Â/g, 'a')
            .replace(/â€™/g, "'")
            .replace(/â€œ/g, '"')
            .replace(/â€\u009d/g, '"')
            .replace(/€™/g, "'")
            
            // Correcciones específicas de palabras mal formadas
            .replace(/Resolucian/gi, 'Resolucion')
            .replace(/Resolucin/gi, 'Resolucion')
            
            // Diccionario de acentos: convertir á→a, é→e, etc.
            .replace(/á/g, 'a')
            .replace(/à/g, 'a')
            .replace(/â/g, 'a')
            .replace(/ä/g, 'a')
            .replace(/ã/g, 'a')
            .replace(/Á/g, 'A')
            .replace(/À/g, 'A')
            .replace(/Â/g, 'A')
            .replace(/Ä/g, 'A')
            .replace(/Ã/g, 'A')
            
            .replace(/é/g, 'e')
            .replace(/è/g, 'e')
            .replace(/ê/g, 'e')
            .replace(/ë/g, 'e')
            .replace(/É/g, 'E')
            .replace(/È/g, 'E')
            .replace(/Ê/g, 'E')
            .replace(/Ë/g, 'E')
            
            .replace(/í/g, 'i')
            .replace(/ì/g, 'i')
            .replace(/î/g, 'i')
            .replace(/ï/g, 'i')
            .replace(/Í/g, 'I')
            .replace(/Ì/g, 'I')
            .replace(/Î/g, 'I')
            .replace(/Ï/g, 'I')
            
            .replace(/ó/g, 'o')
            .replace(/ò/g, 'o')
            .replace(/ô/g, 'o')
            .replace(/ö/g, 'o')
            .replace(/õ/g, 'o')
            .replace(/Ó/g, 'O')
            .replace(/Ò/g, 'O')
            .replace(/Ô/g, 'O')
            .replace(/Ö/g, 'O')
            .replace(/Õ/g, 'O')
            
            .replace(/ú/g, 'u')
            .replace(/ù/g, 'u')
            .replace(/û/g, 'u')
            .replace(/ü/g, 'u')
            .replace(/Ú/g, 'U')
            .replace(/Ù/g, 'U')
            .replace(/Û/g, 'U')
            .replace(/Ü/g, 'U')
            
            // Casos especiales
            .replace(/ñ/g, 'n')
            .replace(/Ñ/g, 'N')
            .replace(/ç/g, 'c')
            .replace(/Ç/g, 'C')
            
            // Limpiar símbolos de pulgadas problemáticos
            .replace(/[��″"]/g, ' pulgadas')
            .replace(/pulgadas pulgadas/g, ' pulgadas')
            
            // Limpiar espacios múltiples
            .replace(/\s+/g, ' ')
            .trim();
        }
        %>
        <%= cleanText(product.description) %>
      </p>
    <% } %>
    
    <p class="product-space estado">
      <%= product.estado %>
    </p>
    <p class="product-space almacenamiento">
      <%= product.almacenamiento %> GB
    </p>

    <p class="product-price precio">
      USD <%= product.price %>
    </p>

    <div class="product-footer">
      <div class="battery-status">
        <img src="/imgs/bateria.png" alt="Battery Icon" class="battery-icon">
        <p class="bateria">
          <span class="bateria-num">
            <%= product.bateria %>
          </span>% 
        </p>
      </div>
      
      <!-- Botón para redirigir a la hoja de producto -->
      <form action="/product" method="POST" class="d-inline" onclick="event.stopPropagation()">
        <input type="hidden" name="productId" value="<%= product.id %>">
        <button type="submit" class="btn-ver-mas-small">Ver más</button>
      </form>
      
      
    </div>
  </div>
</div>
