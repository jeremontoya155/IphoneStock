# Configuración de la base de datos PostgreSQL
DB_USER=tu_usuario
DB_HOST=tu_host
DB_NAME=tu_base_de_datos
DB_PASSWORD=tu_contraseña
DB_PORT=5432

# Configuración de Cloudinary
CLOUD_NAME=tu_cloud_name
API_KEY=tu_api_key
API_SECRET=tu_api_secret

# Sesión
SESSION_SECRET=tu_secret_key_para_sesiones

# Puerto del servidor
PORT=3000

# URL base del sitio (para SEO y sitemap)
BASE_URL=https://iloop.com.ar
